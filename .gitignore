node_modules/
apps/*/node_modules/
packages/*/node_modules/
.next/
apps/*/.next/
apps/*/.turbo/
.turbo/
dist/
apps/*/dist/
packages/*/dist/
contracts/lib/
contracts/out/
contracts/cache/
contracts/broadcast/

# Solana / Anchor / Cargo build outputs
target/
Cargo.lock
*.so

# Per-chain deployment outputs default to local-only. Public reference
# deployments (e.g. mainnet) are exempted below so the SDK can load
# addresses from the repo.
deployments/*.json
!deployments/polygon.json

# Secrets — never commit
.env
.env.*
!.env.example
.env.deployer

# Build cruft
*.tsbuildinfo
next-env.d.ts
.DS_Store
Thumbs.db
*.log

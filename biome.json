{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "node_modules",
      "**/node_modules",
      "dist",
      "**/dist",
      ".turbo",
      "**/.turbo",
      ".next",
      "**/.next",
      ".vercel",
      "**/.vercel",
      "contracts/lib",
      "contracts/out",
      "contracts/cache",
      "contracts/broadcast",
      "deployments",
      "programs",
      "target",
      "**/target",
      "*.tsbuildinfo",
      "**/*.tsbuildinfo",
      "next-env.d.ts",
      "**/next-env.d.ts"
    ]
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noConsoleLog": "off",
        "noArrayIndexKey": "off",
        "noCommentText": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "warn",
        "useSingleVarDeclarator": "off",
        "useTemplate": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 110
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  }
}
